{
  "expo": {
    "name": "Salapify",
    "slug": "salapify-v2",
    "owner": "icedamericanodev",
    "version": "1.2.1",
    "orientation": "portrait",
    "scheme": "salapify",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "updates": {
      "url": "https://u.expo.dev/8bc5a127-b145-41c3-a4f4-790afd91c9f2"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#F4813F"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Salapify uses the camera so you can photograph receipts for your entries.",
          "photosPermission": "Salapify opens your photos so you can attach receipts to your entries.",
          "microphonePermission": false
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "BudgetWidget",
              "label": "Salapify Budget",
              "description": "How much you have left to spend this month",
              "minWidth": "180dp",
              "minHeight": "80dp",
              "targetCellWidth": 3,
              "targetCellHeight": 1,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "NetWorthWidget",
              "label": "Salapify Net Worth",
              "description": "Your net worth at a glance",
              "minWidth": "180dp",
              "minHeight": "80dp",
              "targetCellWidth": 3,
              "targetCellHeight": 1,
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#101E15"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.icedamericanodev.salapify"
    },
    "android": {
      "package": "com.icedamericanodev.salapify",
      "allowBackup": false,
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground.png",
        "backgroundColor": "#FFA45C"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8bc5a127-b145-41c3-a4f4-790afd91c9f2"
      }
    }
  }
}